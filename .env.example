# Social Engine Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Primary Client ──────────────────────────────────────────────────────────
# Blotato API key (from your Blotato account settings > API)
BLOTATO_API_KEY=your_blotato_api_key_here

# ── AI Content Generation ───────────────────────────────────────────────────
# Google Gemini API key (free tier available at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Second Client (optional) ─────────────────────────────────────────────────
# If running the engine for a second client, add their Blotato API key here
# Reference this env var in their clients/{slug}.json under blotato.api_key_env
# SECOND_CLIENT_BLOTATO_API_KEY=their_blotato_api_key_here

# ── LinkedIn (optional) ──────────────────────────────────────────────────────
# Only needed if posting as a LinkedIn company page
# LINKEDIN_AUTHOR_URN=urn:li:person:YOUR_LINKEDIN_URN
